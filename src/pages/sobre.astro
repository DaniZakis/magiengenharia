---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.vue';

const stats = [
  { value: '15+', label: 'Anos de Experiência' },
  { value: '500+', label: 'Projetos Entregues' },
  { value: '98%', label: 'Clientes Satisfeitos' },
  { value: '25+', label: 'Profissionais' },
];

const values = [
  {
    icon: 'shield',
    title: 'Segurança',
    description: 'Compromisso absoluto com a segurança em todos os projetos e serviços que realizamos.'
  },
  {
    icon: 'award',
    title: 'Excelência',
    description: 'Buscamos a excelência técnica em cada detalhe, garantindo resultados de alta qualidade.'
  },
  {
    icon: 'users',
    title: 'Compromisso',
    description: 'Relacionamento transparente e duradouro com nossos clientes e parceiros.'
  },
  {
    icon: 'lightbulb',
    title: 'Inovação',
    description: 'Aplicamos tecnologias e metodologias inovadoras para soluções mais eficientes.'
  },
];

const team = [
  {
    name: 'Eng. Ricardo Maggi',
    role: 'Diretor Técnico',
    description: 'Engenheiro Mecânico com mais de 15 anos de experiência em segurança do trabalho e projetos industriais.'
  },
  {
    name: 'Equipe Técnica',
    role: 'Engenheiros e Técnicos',
    description: 'Profissionais especializados em diversas áreas da engenharia, prontos para atender suas demandas.'
  },
];
---

<BaseLayout title="Quem Somos | Maggi Engenharia" description="Conheça a Maggi Engenharia: mais de 15 anos de experiência em soluções de engenharia, segurança do trabalho e consultoria técnica.">
  <!-- Compact Gradient Header -->
  <section class="relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-primary via-secondary to-dark">
    <!-- Background Decorations -->
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-black/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.02] rounded-full blur-3xl"></div>
      <!-- Grid Pattern -->
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <div class="container-max px-4 md:px-6 relative">
      <div class="flex flex-col lg:flex-row lg:items-center gap-8 lg:gap-12">
        <!-- Icon Container -->
        <div class="flex-shrink-0">
          <div class="w-32 h-32 md:w-40 md:h-40 bg-white rounded-3xl shadow-2xl flex items-center justify-center transform hover:scale-105 transition-all duration-300">
            <div class="text-primary">
              <svg class="w-16 h-16 md:w-20 md:h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
          </div>
        </div>
        
        <!-- Text Content -->
        <div class="flex-1">
          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-white/50 text-sm mb-4">
            <a href="/" class="hover:text-white/80 transition-colors">Home</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-white/80">Quem Somos</span>
          </nav>

          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-6">
            <span class="w-2 h-2 bg-white/80 rounded-full"></span>
            <span class="text-white/90 text-sm font-medium">Desde 2010</span>
          </div>

          <!-- Title -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            Quem Somos
          </h1>

          <!-- Description -->
          <p class="text-xl text-white/80 max-w-2xl leading-relaxed">
            Somos uma empresa especializada em engenharia e segurança do trabalho, comprometida com a excelência e a segurança dos nossos clientes.
          </p>

          <!-- Quick Stats -->
          <div class="flex flex-wrap gap-6 mt-8">
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm">Empresa Certificada</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-sm">São Paulo, SP</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="text-sm">CREA Ativo</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-white border-b border-gray-100">
    <div class="container-max px-4 md:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <span class="text-4xl md:text-5xl font-bold text-primary block">{stat.value}</span>
            <span class="text-dark/60 text-sm mt-2 block">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Content -->
  <section class="py-16 md:py-20 bg-light">
    <div class="container-max px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Text Content -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-dark mb-6">
            Nossa História
          </h2>
          <div class="space-y-4 text-dark/70 leading-relaxed">
            <p>
              A <strong class="text-dark">Maggi Engenharia</strong> nasceu em 2010 com a missão de oferecer soluções completas em engenharia e segurança do trabalho para empresas de todos os portes.
            </p>
            <p>
              Ao longo de mais de 15 anos, construímos uma trajetória sólida baseada na excelência técnica, no compromisso com a segurança e na satisfação dos nossos clientes.
            </p>
            <p>
              Nossa equipe é formada por engenheiros e técnicos altamente qualificados, com vasta experiência em projetos industriais, adequação de máquinas, gestão de SST e muito mais.
            </p>
            <p>
              Atuamos em diversos segmentos da indústria, sempre com foco na qualidade, cumprimento de prazos e total conformidade com as normas regulamentadoras.
            </p>
          </div>
        </div>

        <!-- Image/Visual -->
        <div class="relative">
          <div class="bg-gradient-to-br from-primary/10 to-secondary/10 rounded-3xl p-8 md:p-12">
            <div class="bg-white rounded-2xl shadow-xl p-8">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center">
                  <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-dark">Missão</h3>
                </div>
              </div>
              <p class="text-dark/70 leading-relaxed">
                Oferecer soluções de engenharia e segurança do trabalho com excelência, contribuindo para ambientes de trabalho mais seguros e eficientes.
              </p>
            </div>

            <div class="bg-white rounded-2xl shadow-xl p-8 mt-6">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 bg-secondary/10 rounded-2xl flex items-center justify-center">
                  <svg class="w-8 h-8 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-dark">Visão</h3>
                </div>
              </div>
              <p class="text-dark/70 leading-relaxed">
                Ser referência nacional em engenharia e segurança do trabalho, reconhecida pela qualidade, inovação e compromisso com nossos clientes.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-max px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Nossos Valores</h2>
        <p class="text-dark/60 max-w-2xl mx-auto">
          Princípios que guiam nossa atuação e garantem a qualidade dos nossos serviços
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value) => (
          <div class="bg-light rounded-2xl p-8 text-center hover:shadow-lg transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
              {value.icon === 'shield' && (
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              )}
              {value.icon === 'award' && (
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                </svg>
              )}
              {value.icon === 'users' && (
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
              )}
              {value.icon === 'lightbulb' && (
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">{value.title}</h3>
            <p class="text-dark/60 text-sm">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 md:py-20 bg-light">
    <div class="container-max px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Nossa Equipe</h2>
        <p class="text-dark/60 max-w-2xl mx-auto">
          Profissionais qualificados e comprometidos com a excelência
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {team.map((member) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
            <div class="flex items-start gap-6">
              <div class="w-20 h-20 bg-gradient-to-br from-primary to-secondary rounded-2xl flex items-center justify-center flex-shrink-0">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-dark mb-1">{member.name}</h3>
                <span class="text-primary font-medium text-sm block mb-3">{member.role}</span>
                <p class="text-dark/60 text-sm">{member.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-max px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Certificações e Registros</h2>
        <p class="text-dark/60 max-w-2xl mx-auto">
          Atuamos com total conformidade legal e registros profissionais ativos
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="bg-light rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">CREA-SP</h3>
          <p class="text-dark/60 text-sm">Registro ativo no Conselho Regional de Engenharia</p>
        </div>

        <div class="bg-light rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">ART</h3>
          <p class="text-dark/60 text-sm">Emissão de Anotação de Responsabilidade Técnica</p>
        </div>

        <div class="bg-light rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">NRs</h3>
          <p class="text-dark/60 text-sm">Conformidade com Normas Regulamentadoras</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    client:load
    title="Vamos Trabalhar Juntos?"
    description="Entre em contato conosco para conhecer mais sobre nossos serviços e como podemos ajudar sua empresa."
    primaryLabel="Fale Conosco"
    primaryUrl="/contato"
    secondaryLabel="Ver Serviços"
    secondaryUrl="/servicos"
  />
</BaseLayout>
