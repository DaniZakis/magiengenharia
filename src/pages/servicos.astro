---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.vue';
import ServiceCard from '../components/ServiceCard.vue';
import CTASection from '../components/CTASection.vue';

// Placeholder services data - will be replaced with CMS data
const services = [
  {
    title: 'Consultoria Técnica',
    slug: 'consultoria-tecnica',
    description: 'Assessoria especializada em projetos de engenharia',
    shortDescription: 'Soluções técnicas personalizadas para otimizar seus projetos',
    icon: '📋',
  },
  {
    title: 'Projetos Estruturais',
    slug: 'projetos-estruturais',
    description: 'Desenvolvimento completo de projetos estruturais',
    shortDescription: 'Projetos robustos e inovadores para suas construções',
    icon: '🏗️',
  },
  {
    title: 'Avaliações e Perícias',
    slug: 'avaliacoes-pericias',
    description: 'Avaliações detalhadas e relatórios de perícia',
    shortDescription: 'Laudos técnicos precisos e confiáveis',
    icon: '🔍',
  },
  {
    title: 'Projetos de Instalações',
    slug: 'projetos-instalacoes',
    description: 'Projetos especializados de sistemas e instalações',
    shortDescription: 'Soluções completas para instalações prediais',
    icon: '⚙️',
  },
  {
    title: 'Reformas e Restauração',
    slug: 'reformas-restauracao',
    description: 'Acompanhamento técnico em reformas e projetos de restauração',
    shortDescription: 'Preservação e modernização de estruturas existentes',
    icon: '🔧',
  },
  {
    title: 'Laudos Técnicos',
    slug: 'laudos-tecnicos',
    description: 'Elaboração de laudos técnicos especializados',
    shortDescription: 'Documentação técnica detalhada e precisa',
    icon: '📄',
  },
];
---

<BaseLayout title="Serviços | Maggi Engenharia" description="Conheça todos os serviços especializados de engenharia oferecidos pela Maggi Engenharia.">
  <!-- Hero Section -->
  <HeroSection
    client:load
    title="Nossos Serviços"
    subtitle="Soluções completas em engenharia para todos os seus projetos"
  />

  <!-- Services Section -->
  <section class="section-padding bg-light">
    <div class="container-max">
      <!-- Introduction -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-dark mb-4">
          Especializados em Diferentes Áreas
        </h2>
        <p class="text-lg text-dark/70 max-w-2xl mx-auto">
          Cada serviço é desenvolvido por profissionais experientes com expertise em suas respectivas áreas de atuação.
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          services.map((service) => (
            <ServiceCard client:load service={service} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    client:load
    title="Não encontrou o serviço que procura?"
    description="Entre em contato conosco para discussões sobre projetos personalizados e soluções especializadas."
    primaryLabel="Solicitar Consultoria"
    primaryUrl="/contato"
    secondaryLabel="Chat WhatsApp"
    showWhatsApp={true}
  />
</BaseLayout>
