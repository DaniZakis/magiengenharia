---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.vue';
import { getServicesArray, getCategories } from '../data/services';

const allServices = getServicesArray();
const categories = getCategories();

// Icon components map
const icons: Record<string, string> = {
  'shield-check': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  'building': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  'award': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
  'clipboard-list': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>`,
  'document-text': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  'link': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`,
  'users': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  'cog': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  'search': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
  'folder': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>`,
  'fire': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/></svg>`,
  'academic-cap': `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/></svg>`,
};

const getIcon = (iconName: string) => icons[iconName] || icons['document-text'];

// Muted, harmonious category colors - earthy tones that complement gold/brown brand
const categoryColors: Record<string, string> = {
  'Segurança do Trabalho': 'bg-stone-100 text-stone-700 border-stone-200',
  'Documentação Técnica': 'bg-slate-100 text-slate-700 border-slate-200',
  'Engenharia Estrutural': 'bg-amber-50 text-amber-800 border-amber-200',
  'Engenharia Mecânica': 'bg-zinc-100 text-zinc-700 border-zinc-200',
  'Capacitação': 'bg-emerald-50 text-emerald-800 border-emerald-200',
  'Segurança': 'bg-orange-50 text-orange-900 border-orange-200',
  'Recursos Humanos': 'bg-sky-50 text-sky-800 border-sky-200',
  'Institucional': 'bg-primary/10 text-primary border-primary/20',
};

const getCategoryColor = (category: string) => categoryColors[category] || 'bg-gray-100 text-gray-700 border-gray-200';
---

<BaseLayout title="Serviços | Maggi Engenharia" description="Conheça todos os serviços especializados de engenharia oferecidos pela Maggi Engenharia.">
  <!-- Hero Section -->
  <section class="relative bg-dark py-24 md:py-32 overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-[0.03]">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
    
    <div class="container-max px-4 md:px-6 relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
          <span class="w-2 h-2 bg-primary rounded-full"></span>
          <span class="text-primary text-sm font-medium">Soluções Completas</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
          Nossos Serviços
        </h1>
        <p class="text-xl text-white/70 max-w-2xl">
          Oferecemos um portfólio completo de serviços de engenharia, segurança do trabalho e documentação técnica para atender todas as necessidades da sua empresa.
        </p>
        
        <!-- Category Summary -->
        <div class="flex flex-wrap gap-2 mt-8">
          {categories.map((cat) => (
            <span class={`px-3 py-1.5 rounded-full text-xs font-medium border ${getCategoryColor(cat)}`}>
              {cat}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- All Services Grid -->
  <section class="py-16 md:py-24 bg-light">
    <div class="container-max px-4 md:px-6">
      <!-- Section Header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">
          {allServices.length} Serviços Especializados
        </h2>
        <p class="text-dark/60 max-w-2xl mx-auto">
          Soluções completas para sua empresa, desde segurança do trabalho até projetos de engenharia
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {allServices.map((service) => (
          <a 
            href={`/servicos/${service.slug}`} 
            class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col h-full border border-gray-100"
          >
            <!-- Icon -->
            <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-4 group-hover:bg-primary group-hover:text-white transition-all duration-300">
              <Fragment set:html={getIcon(service.icon)} />
            </div>
            
            <!-- Category Badge -->
            <span class={`self-start px-2.5 py-1 rounded-full text-[10px] font-semibold uppercase tracking-wider border mb-3 ${getCategoryColor(service.category)}`}>
              {service.category}
            </span>
            
            <!-- Title -->
            <h3 class="text-lg font-bold text-dark group-hover:text-primary transition-colors mb-2 leading-tight">
              {service.title}
            </h3>
            
            <!-- Description -->
            <p class="text-sm text-dark/60 mb-4 flex-grow line-clamp-3">
              {service.shortDescription}
            </p>
            
            <!-- Link -->
            <div class="flex items-center text-primary font-semibold text-sm mt-auto pt-4 border-t border-gray-100">
              <span>Ver detalhes</span>
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 bg-dark">
    <div class="container-max px-4 md:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <span class="text-4xl md:text-5xl font-bold text-primary block mb-2">12</span>
          <span class="text-white/60">Serviços Especializados</span>
        </div>
        <div>
          <span class="text-4xl md:text-5xl font-bold text-primary block mb-2">500+</span>
          <span class="text-white/60">Projetos Entregues</span>
        </div>
        <div>
          <span class="text-4xl md:text-5xl font-bold text-primary block mb-2">15+</span>
          <span class="text-white/60">Anos de Experiência</span>
        </div>
        <div>
          <span class="text-4xl md:text-5xl font-bold text-primary block mb-2">98%</span>
          <span class="text-white/60">Satisfação dos Clientes</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    client:load
    title="Não encontrou o serviço que procura?"
    description="Entre em contato conosco para discussões sobre projetos personalizados e soluções especializadas."
    primaryLabel="Solicitar Consultoria"
    primaryUrl="/contato"
    secondaryLabel="Chat WhatsApp"
    showWhatsApp={true}
  />
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
