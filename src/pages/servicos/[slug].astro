export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map((entry) => ({
    params: { slug: entry.data.slug || entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const service = {
  title: entry.data.title,
  slug: entry.data.slug || entry.slug,
  icon: entry.data.icon || 'document-text',
  category: entry.data.category || 'Geral',
  description: entry.data.description,
  shortDescription: entry.data.shortDescription,
  image: entry.data.image,
  benefits: entry.data.benefits || [],
  relatedServices: entry.data.relatedServices || [],
};

// Fetch all services for related services lookup
const allServiceEntries = await getCollection('services');

const relatedServices = service.relatedServices
  .map((relSlug: string) => {
    const found = allServiceEntries.find(e => (e.data.slug || e.slug) === relSlug);
    if (!found) return null;
    return {
      title: found.data.title,
      slug: found.data.slug || found.slug,
      icon: found.data.icon || 'document-text',
      category: found.data.category || 'Geral',
      shortDescription: found.data.shortDescription,
    };
  })
  .filter(Boolean);

const style = getStyle(service.category);
const getIcon = (iconName: string) => icons[iconName] || icons['document-text'];
const getMediumIcon = (iconName: string) => mediumIcons[iconName] || mediumIcons['document-text'];
---

<BaseLayout title={`${service.title} | Maggi Engenharia`} description={service.description}>
  <!-- Service Header - Category Colored (Muted Tones) -->
  <section class={`relative py-20 md:py-28 overflow-hidden bg-gradient-to-br ${style.gradient}`}>
    <!-- Background Decorations -->
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-black/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.02] rounded-full blur-3xl"></div>
      <!-- Grid Pattern -->
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <div class="container-max px-4 md:px-6 relative">
      <div class="flex flex-col lg:flex-row lg:items-center gap-8 lg:gap-12">
        <!-- Icon Container -->
        <div class="flex-shrink-0">
          <div class="w-32 h-32 md:w-40 md:h-40 bg-white rounded-3xl shadow-2xl flex items-center justify-center transform hover:scale-105 transition-all duration-300">
            <div class={style.iconColor}>
              <Fragment set:html={getIcon(service.icon)} />
            </div>
          </div>
        </div>
        
        <!-- Text Content -->
        <div class="flex-1">
          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-white/50 text-sm mb-4">
            <a href="/" class="hover:text-white/80 transition-colors">Home</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <a href="/servicos" class="hover:text-white/80 transition-colors">Serviços</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-white/80">{service.title}</span>
          </nav>

          <!-- Category Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-6">
            <span class="w-2 h-2 bg-white/80 rounded-full"></span>
            <span class="text-white/90 text-sm font-medium">{service.category}</span>
          </div>

          <!-- Title -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            {service.title}
          </h1>

          <!-- Description -->
          <p class="text-xl text-white/80 max-w-2xl leading-relaxed">
            {service.description}
          </p>

          <!-- Quick Stats -->
          <div class="flex flex-wrap gap-6 mt-8">
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm">Profissionais Certificados</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm">Atendimento Ágil</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <span class="text-sm">Documentação Completa</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Content -->
  <section class="py-16 md:py-20 bg-light">
    <div class="container-max px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 md:p-10">
            <!-- Featured Image -->
            {service.image && (
              <div class="mb-8 -mt-2 -mx-2 md:-mt-4 md:-mx-4">
                <img src={service.image} alt={service.title} class="w-full rounded-2xl object-cover" />
              </div>
            )}

            <!-- Intro -->
            <p class="text-lg text-dark/80 leading-relaxed mb-8 pb-8 border-b border-gray-100">
              {service.shortDescription}
            </p>
            
            <!-- Content -->
            <div class="prose prose-lg max-w-none text-dark">
              <Content />
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-6">
          <!-- Benefits Card -->
          <div class={`rounded-3xl p-8 ${style.lightBg} border ${style.borderColor}`}>
            <div class="flex items-center gap-3 mb-6">
              <div class={`w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center ${style.iconColor}`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-dark">Vantagens</h3>
            </div>
            <ul class="space-y-4">
              {
                service.benefits.map((benefit: string) => (
                  <li class="flex items-start gap-3">
                    <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${style.iconColor}`} fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-dark/80 text-sm">{benefit}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Contact Card -->
          <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
            <h3 class="text-xl font-bold text-dark mb-4">Solicite um Orçamento</h3>
            <p class="text-dark/60 text-sm mb-6">
              Nossa equipe está pronta para atender sua demanda com agilidade e qualidade.
            </p>
            <a 
              href="/contato" 
              class="block w-full py-4 px-6 bg-primary text-white text-center font-semibold rounded-xl transition-all duration-300 hover:bg-secondary hover:shadow-lg"
            >
              Fale Conosco
            </a>
            <a 
              href="https://wa.me/5511999948676" 
              target="_blank"
              class="flex items-center justify-center gap-2 w-full py-4 px-6 mt-3 bg-emerald-700 text-white font-semibold rounded-xl hover:bg-emerald-800 transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="py-16 md:py-20 bg-white">
      <div class="container-max px-4 md:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Serviços Relacionados</h2>
          <p class="text-dark/60 max-w-2xl mx-auto">Conheça outros serviços que podem complementar suas necessidades</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            relatedServices.map((relatedService: any) => {
              const relatedStyle = getStyle(relatedService.category);
              return (
                <a href={`/servicos/${relatedService.slug}`} class="group">
                  <div class="bg-light rounded-2xl overflow-hidden h-full hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
                    <!-- Colored Header -->
                    <div class={`h-24 bg-gradient-to-r ${relatedStyle.gradient} flex items-center justify-center relative overflow-hidden`}>
                      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors"></div>
                      <div class="w-16 h-16 bg-white rounded-xl shadow-lg flex items-center justify-center group-hover:scale-110 transition-transform">
                        <div class={relatedStyle.iconColor}>
                          <Fragment set:html={getMediumIcon(relatedService.icon)} />
                        </div>
                      </div>
                    </div>
                    <!-- Content -->
                    <div class="p-6">
                      <span class={`text-xs font-semibold uppercase tracking-wider ${relatedStyle.iconColor}`}>
                        {relatedService.category}
                      </span>
                      <h3 class="text-xl font-bold text-dark group-hover:text-primary transition-colors mt-2 mb-3">
                        {relatedService.title}
                      </h3>
                      <p class="text-sm text-dark/60 mb-4 line-clamp-2">
                        {relatedService.shortDescription}
                      </p>
                      <span class="inline-flex items-center text-primary font-semibold text-sm">
                        Saiba Mais 
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                      </span>
                    </div>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <CTASection
    client:load
    title={`Interessado em ${service.title}?`}
    description="Entre em contato conosco para discutir como podemos ajudar com seu projeto."
    primaryLabel="Solicitar Orçamento"
    primaryUrl="/contato"
    secondaryLabel="Chat WhatsApp"
    showWhatsApp={true}
  />
</BaseLayout>

