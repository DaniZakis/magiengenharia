---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.vue';
import { getCollection } from 'astro:content';

// Muted, harmonious category styling - earthy tones that complement gold/brown brand
const categoryStyles: Record<string, { gradient: string; iconColor: string; lightBg: string; borderColor: string }> = {
  'Segurança do Trabalho': {
    gradient: 'from-stone-600 via-stone-700 to-stone-800',
    iconColor: 'text-stone-600',
    lightBg: 'bg-stone-50',
    borderColor: 'border-stone-200'
  },
  'Documentação Técnica': {
    gradient: 'from-slate-500 via-slate-600 to-slate-700',
    iconColor: 'text-slate-600',
    lightBg: 'bg-slate-50',
    borderColor: 'border-slate-200'
  },
  'Engenharia Estrutural': {
    gradient: 'from-amber-700 via-amber-800 to-amber-900',
    iconColor: 'text-amber-700',
    lightBg: 'bg-amber-50',
    borderColor: 'border-amber-200'
  },
  'Engenharia Mecânica': {
    gradient: 'from-zinc-600 via-zinc-700 to-zinc-800',
    iconColor: 'text-zinc-600',
    lightBg: 'bg-zinc-50',
    borderColor: 'border-zinc-200'
  },
  'Capacitação': {
    gradient: 'from-emerald-700 via-emerald-800 to-emerald-900',
    iconColor: 'text-emerald-700',
    lightBg: 'bg-emerald-50',
    borderColor: 'border-emerald-200'
  },
  'Segurança': {
    gradient: 'from-orange-800 via-orange-900 to-orange-950',
    iconColor: 'text-orange-800',
    lightBg: 'bg-orange-50',
    borderColor: 'border-orange-200'
  },
  'Recursos Humanos': {
    gradient: 'from-sky-700 via-sky-800 to-sky-900',
    iconColor: 'text-sky-700',
    lightBg: 'bg-sky-50',
    borderColor: 'border-sky-200'
  },
  'Institucional': {
    gradient: 'from-primary via-secondary to-dark',
    iconColor: 'text-primary',
    lightBg: 'bg-primary/5',
    borderColor: 'border-primary/20'
  },
};

const getStyle = (category: string) => categoryStyles[category] || {
  gradient: 'from-dark via-secondary to-dark',
  iconColor: 'text-primary',
  lightBg: 'bg-light',
  borderColor: 'border-gray-200'
};

// Large icons for header
const icons: Record<string, string> = {
