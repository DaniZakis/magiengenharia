---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogPosts, getCategories } from '../data/blog';

const categories = getCategories();

// Sort posts by date (newest first)
const sortedPosts = [...blogPosts].sort((a, b) => 
  new Date(b.date).getTime() - new Date(a.date).getTime()
);

const featuredPost = sortedPosts.find(post => post.featured);
const otherPosts = sortedPosts.filter(post => post !== featuredPost);

// Format date helper
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('pt-BR', { 
    day: '2-digit', 
    month: 'long', 
    year: 'numeric' 
  });
};

// Category colors
const categoryColors: Record<string, { bg: string; text: string }> = {
  'Segurança do Trabalho': { bg: 'bg-stone-100', text: 'text-stone-700' },
  'Documentação': { bg: 'bg-slate-100', text: 'text-slate-700' },
  'Engenharia': { bg: 'bg-amber-100', text: 'text-amber-700' },
  'Treinamentos': { bg: 'bg-emerald-100', text: 'text-emerald-700' },
};

const getCategoryStyle = (category: string) => 
  categoryColors[category] || { bg: 'bg-primary/10', text: 'text-primary' };
---

<BaseLayout title="Blog | Maggi Engenharia" description="Artigos e notícias sobre engenharia, segurança do trabalho, normas regulamentadoras e muito mais.">
  <!-- Compact Gradient Header -->
  <section class="relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-primary via-secondary to-dark">
    <!-- Background Decorations -->
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-black/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.02] rounded-full blur-3xl"></div>
      <!-- Grid Pattern -->
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <div class="container-max px-4 md:px-6 relative">
      <div class="flex flex-col lg:flex-row lg:items-center gap-8 lg:gap-12">
        <!-- Icon Container -->
        <div class="flex-shrink-0">
          <div class="w-32 h-32 md:w-40 md:h-40 bg-white rounded-3xl shadow-2xl flex items-center justify-center transform hover:scale-105 transition-all duration-300">
            <div class="text-primary">
              <svg class="w-16 h-16 md:w-20 md:h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
            </div>
          </div>
        </div>
        
        <!-- Text Content -->
        <div class="flex-1">
          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-white/50 text-sm mb-4">
            <a href="/" class="hover:text-white/80 transition-colors">Home</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-white/80">Blog</span>
          </nav>

          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-6">
            <span class="w-2 h-2 bg-white/80 rounded-full"></span>
            <span class="text-white/90 text-sm font-medium">Conhecimento Técnico</span>
          </div>

          <!-- Title -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            Blog
          </h1>

          <!-- Description -->
          <p class="text-xl text-white/80 max-w-2xl leading-relaxed">
            Artigos, notícias e conteúdos técnicos sobre engenharia, segurança do trabalho e normas regulamentadoras.
          </p>

          <!-- Categories Pills -->
          <div class="flex flex-wrap gap-3 mt-8">
            {categories.map((category) => (
              <span class="px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-white/90 text-sm">
                {category}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="py-12 bg-white border-b border-gray-100">
      <div class="container-max px-4 md:px-6">
        <div class="flex items-center gap-2 mb-8">
          <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span class="text-sm font-semibold text-dark uppercase tracking-wider">Destaque</span>
        </div>

        <a href={`/blog/${featuredPost.slug}`} class="group block">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <!-- Image Placeholder -->
            <div class="aspect-video bg-gradient-to-br from-primary/10 to-secondary/10 rounded-2xl overflow-hidden flex items-center justify-center group-hover:shadow-xl transition-shadow">
              <div class="text-center p-8">
                <svg class="w-16 h-16 text-primary/30 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                </svg>
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${getCategoryStyle(featuredPost.category).bg} ${getCategoryStyle(featuredPost.category).text}`}>
                  {featuredPost.category}
                </span>
              </div>
            </div>

            <!-- Content -->
            <div>
              <div class="flex items-center gap-4 text-sm text-dark/60 mb-4">
                <span>{formatDate(featuredPost.date)}</span>
                <span>•</span>
                <span>{featuredPost.readTime} de leitura</span>
              </div>
              <h2 class="text-2xl md:text-3xl font-bold text-dark mb-4 group-hover:text-primary transition-colors">
                {featuredPost.title}
              </h2>
              <p class="text-dark/70 mb-6 line-clamp-3">
                {featuredPost.excerpt}
              </p>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  </div>
                  <span class="text-sm font-medium text-dark">{featuredPost.author}</span>
                </div>
                <span class="inline-flex items-center text-primary font-semibold text-sm group-hover:gap-2 transition-all">
                  Ler Artigo 
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- All Posts Grid -->
  <section class="py-16 md:py-20 bg-light">
    <div class="container-max px-4 md:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-8">Todos os Artigos</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {otherPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group">
            <article class="bg-white rounded-2xl overflow-hidden h-full hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
              <!-- Image Placeholder -->
              <div class="aspect-video bg-gradient-to-br from-primary/5 to-secondary/5 flex items-center justify-center relative">
                <svg class="w-12 h-12 text-primary/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                </svg>
                <span class={`absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-medium ${getCategoryStyle(post.category).bg} ${getCategoryStyle(post.category).text}`}>
                  {post.category}
                </span>
              </div>

              <!-- Content -->
              <div class="p-6">
                <div class="flex items-center gap-3 text-sm text-dark/50 mb-3">
                  <span>{formatDate(post.date)}</span>
                  <span>•</span>
                  <span>{post.readTime}</span>
                </div>
                <h3 class="text-lg font-bold text-dark mb-3 group-hover:text-primary transition-colors line-clamp-2">
                  {post.title}
                </h3>
                <p class="text-sm text-dark/60 mb-4 line-clamp-2">
                  {post.excerpt}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-dark/70">{post.author}</span>
                  <span class="inline-flex items-center text-primary font-semibold text-sm">
                    Ler
                    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary via-secondary to-dark">
    <div class="container-max px-4 md:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Fique por dentro das novidades
      </h2>
      <p class="text-white/80 max-w-2xl mx-auto mb-8">
        Receba nossos artigos e atualizações sobre segurança do trabalho e engenharia diretamente no seu email.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-md mx-auto">
        <input 
          type="email" 
          placeholder="Seu melhor email"
          class="flex-1 px-6 py-4 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-white/40"
        />
        <button class="px-8 py-4 bg-white text-primary font-semibold rounded-xl hover:bg-white/90 transition-colors">
          Inscrever
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
