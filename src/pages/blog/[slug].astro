---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.vue';
import { blogPosts, getRelatedPosts } from '../../data/blog';
import type { BlogPost } from '../../data/blog';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = blogPosts.find(p => p.slug === slug);

if (!post) {
  return Astro.redirect('/blog');
}

const relatedPosts = getRelatedPosts(slug, 3);

// Format date helper
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('pt-BR', { 
    day: '2-digit', 
    month: 'long', 
    year: 'numeric' 
  });
};

// Category colors
const categoryColors: Record<string, { bg: string; text: string; gradient: string }> = {
  'Segurança do Trabalho': { bg: 'bg-stone-100', text: 'text-stone-700', gradient: 'from-stone-600 via-stone-700 to-stone-800' },
  'Documentação': { bg: 'bg-slate-100', text: 'text-slate-700', gradient: 'from-slate-500 via-slate-600 to-slate-700' },
  'Engenharia': { bg: 'bg-amber-100', text: 'text-amber-700', gradient: 'from-amber-700 via-amber-800 to-amber-900' },
  'Treinamentos': { bg: 'bg-emerald-100', text: 'text-emerald-700', gradient: 'from-emerald-700 via-emerald-800 to-emerald-900' },
};

const getCategoryStyle = (category: string) => 
  categoryColors[category] || { bg: 'bg-primary/10', text: 'text-primary', gradient: 'from-primary via-secondary to-dark' };

const categoryStyle = getCategoryStyle(post.category);
---

<BaseLayout title={`${post.title} | Blog | Maggi Engenharia`} description={post.excerpt}>
  <!-- Article Header -->
  <section class={`relative py-20 md:py-28 overflow-hidden bg-gradient-to-br ${categoryStyle.gradient}`}>
    <!-- Background Decorations -->
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-black/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.02] rounded-full blur-3xl"></div>
      <!-- Grid Pattern -->
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <div class="container-max px-4 md:px-6 relative">
      <div class="max-w-4xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-white/50 text-sm mb-6">
          <a href="/" class="hover:text-white/80 transition-colors">Home</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <a href="/blog" class="hover:text-white/80 transition-colors">Blog</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-white/80 truncate max-w-[200px]">{post.title}</span>
        </nav>

        <!-- Category Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-6">
          <span class="w-2 h-2 bg-white/80 rounded-full"></span>
          <span class="text-white/90 text-sm font-medium">{post.category}</span>
        </div>

        <!-- Title -->
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
          {post.title}
        </h1>

        <!-- Meta Info -->
        <div class="flex flex-wrap items-center gap-6 text-white/70">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <span class="font-medium text-white">{post.author}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span>{formatDate(post.date)}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>{post.readTime} de leitura</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-16 md:py-20 bg-light">
    <div class="container-max px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <article class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 md:p-10">
            <!-- Excerpt -->
            <p class="text-lg text-dark/80 leading-relaxed mb-8 pb-8 border-b border-gray-100 font-medium">
              {post.excerpt}
            </p>
            
            <!-- Content -->
            <div class="prose prose-lg max-w-none text-dark">
              <div set:html={post.content} />
            </div>

            <!-- Share Section -->
            <div class="mt-12 pt-8 border-t border-gray-100">
              <h3 class="text-lg font-bold text-dark mb-4">Compartilhar este artigo</h3>
              <div class="flex gap-3">
                <a 
                  href={`https://wa.me/?text=${encodeURIComponent(post.title + ' - Maggi Engenharia')}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-[#25D366] hover:bg-[#20ba5a] flex items-center justify-center transition-colors"
                >
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 32 32">
                    <path d="M26.576 5.363c-2.69-2.69-6.406-4.354-10.511-4.354-8.209 0-14.865 6.655-14.865 14.865 0 2.732 0.737 5.291 2.022 7.491l-0.038-0.070-2.109 7.702 7.879-2.067c2.051 1.139 4.498 1.809 7.102 1.809h0.006c8.209-0.003 14.862-6.659 14.862-14.868 0-4.103-1.662-7.817-4.349-10.507l0 0z"/>
                  </svg>
                </a>
                <a 
                  href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-[#0077B5] hover:bg-[#006699] flex items-center justify-center transition-colors"
                >
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                </a>
                <a 
                  href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-[#1DA1F2] hover:bg-[#0d8bd9] flex items-center justify-center transition-colors"
                >
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-6">
          <!-- Author Card -->
          <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
            <h3 class="text-lg font-bold text-dark mb-6">Sobre o Autor</h3>
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-dark">{post.author}</h4>
                <p class="text-sm text-dark/60">Maggi Engenharia</p>
              </div>
            </div>
          </div>

          <!-- CTA Card -->
          <div class="bg-gradient-to-br from-primary to-secondary rounded-3xl p-8 text-white">
            <h3 class="text-xl font-bold mb-4">Precisa de ajuda?</h3>
            <p class="text-white/80 text-sm mb-6">
              Nossa equipe está pronta para ajudar com seu projeto de engenharia e segurança do trabalho.
            </p>
            <a 
              href="/contato" 
              class="block w-full py-3 px-6 bg-white text-primary text-center font-semibold rounded-xl hover:bg-white/90 transition-colors"
            >
              Fale Conosco
            </a>
          </div>

          <!-- Categories Card -->
          <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
            <h3 class="text-lg font-bold text-dark mb-6">Categorias</h3>
            <div class="space-y-3">
              <a href="/blog" class={`block px-4 py-2 rounded-xl ${categoryStyle.bg} ${categoryStyle.text} font-medium text-sm hover:opacity-80 transition-opacity`}>
                {post.category}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-20 bg-white">
      <div class="container-max px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-8">Artigos Relacionados</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {relatedPosts.map((relatedPost) => {
            const relatedStyle = getCategoryStyle(relatedPost.category);
            return (
              <a href={`/blog/${relatedPost.slug}`} class="group">
                <article class="bg-light rounded-2xl overflow-hidden h-full hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
                  <!-- Image Placeholder -->
                  <div class="aspect-video bg-gradient-to-br from-primary/5 to-secondary/5 flex items-center justify-center relative">
                    <svg class="w-12 h-12 text-primary/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                    </svg>
                    <span class={`absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-medium ${relatedStyle.bg} ${relatedStyle.text}`}>
                      {relatedPost.category}
                    </span>
                  </div>

                  <!-- Content -->
                  <div class="p-6">
                    <div class="flex items-center gap-3 text-sm text-dark/50 mb-3">
                      <span>{formatDate(relatedPost.date)}</span>
                      <span>•</span>
                      <span>{relatedPost.readTime}</span>
                    </div>
                    <h3 class="text-lg font-bold text-dark mb-3 group-hover:text-primary transition-colors line-clamp-2">
                      {relatedPost.title}
                    </h3>
                    <span class="inline-flex items-center text-primary font-semibold text-sm">
                      Ler Artigo
                      <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </span>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <CTASection
    client:load
    title="Tem alguma dúvida?"
    description="Entre em contato conosco para esclarecer suas dúvidas sobre este tema ou solicitar nossos serviços."
    primaryLabel="Fale Conosco"
    primaryUrl="/contato"
    secondaryLabel="Ver Serviços"
    secondaryUrl="/servicos"
  />
</BaseLayout>

<style>
  :global(.prose) {
    color: inherit;
  }

  :global(.prose h2) {
    @apply text-2xl font-bold text-dark mt-8 mb-4 first:mt-0;
  }

  :global(.prose p) {
    @apply mb-4 text-dark/80 leading-relaxed;
  }

  :global(.prose ul) {
    @apply list-none mb-6 space-y-3 pl-0;
  }

  :global(.prose li) {
    @apply text-dark/80 flex items-start gap-3;
  }

  :global(.prose li::before) {
    content: '';
    @apply w-2 h-2 rounded-full bg-primary flex-shrink-0 mt-2;
  }

  :global(.prose strong) {
    @apply text-dark font-semibold;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
